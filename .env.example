# Copy this file to .env and fill in the values. Do not commit .env.

# Neon Postgres connection strings.
# DATABASE_URL is the pooled connection (host ends with -pooler). Used by the app.
# DIRECT_URL is the direct connection (no -pooler). Used by Prisma migrations.
# Both are shown on the Neon dashboard under Connection Details.
DATABASE_URL="postgresql://USER:PASSWORD@ep-xxxx-pooler.REGION.aws.neon.tech/DBNAME?sslmode=require"
DIRECT_URL="postgresql://USER:PASSWORD@ep-xxxx.REGION.aws.neon.tech/DBNAME?sslmode=require"

# Auth.js secret used to sign session tokens. Generate with: npx auth secret
AUTH_SECRET="replace-with-a-long-random-string"
